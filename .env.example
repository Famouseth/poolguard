# ─── The Graph API ──────────────────────────────────────────────────────────
# Get an API key at https://thegraph.com/studio/
GRAPH_API_KEY=your_graph_api_key_here

# Uniswap V3 subgraph URLs (defaults are free hosted; swap to decentralised network for production)
# Decentralised network IDs:
#   Ethereum: 5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV
#   Base:     43Hwfi3dJSoGpyas9VwNoDAv55yjgGrPpNSmbQZArzMG
#   BNB:      F85MNWutWZNopCH9NMk8DGj6b5cQSmTfZRkjhQnumWRz
SUBGRAPH_URL_ETH=https://api.thegraph.com/subgraphs/name/uniswap/uniswap-v3
SUBGRAPH_URL_BASE=https://api.studio.thegraph.com/query/48211/uniswap-v3-base/version/latest
SUBGRAPH_URL_BNB=https://api.thegraph.com/subgraphs/name/ianlapham/uniswap-v3-bsc

# ─── RPC endpoints (optional overrides) ─────────────────────────────────────
# Defaults use free public RPCs from chainlist.org (LlamaRPC → drpc → 1rpc → publicnode)
# with automatic fallback — no API key needed for development.
# For production, set these to a paid provider (Alchemy/Infura/QuickNode).
# NEXT_PUBLIC_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
# NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key
# NEXT_PUBLIC_BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/your_key

# ─── WalletConnect ──────────────────────────────────────────────────────────
# Register at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ─── DefiLlama (no key needed, used for TVL enrichment) ─────────────────────
# https://defillama.com/docs/api

# ─── Redis / Upstash (optional — for server-side caching) ────────────────────
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
